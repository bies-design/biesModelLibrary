# MinIO (S3 兼容存储) 配置
S3_REGION = "us-east-1"
S3_ACCESS_KEY = "minioadmin"
S3_SECRET_KEY = "minioadmin"
S3_IFC_BUCKET = "ifcfiles"
S3_FRAGS_BUCKET = "frags"
S3_IMAGES_BUCKET = "images"
S3_PDF_BUCKET = "pdf"
S3_HOST = "minio-local" # MinIO Alias for Docker Compose 內部網路使用
S3_PORT = 9000
S3_CONSOLE_PORT = 9001
NEXT_PUBLIC_S3_ENDPOINT= "http://${TARGET_HOST}:${S3_PORT}"
S3_ENDPOINT = "http://${S3_HOST}:${S3_PORT}"
# 常用初始帳號： admin #Admin123@@ 
# 這些是 MinIO 的設定，確保你的 MinIO 服務正在運行，並且這些憑證與你的 MinIO 配置相匹配。

# Redis 配置
REDIS_HOST = "redis-local"
REDIS_PORT = 6379

# Memory Queue 配置
IFC_CONVERSION_Q = "ifc-conversion-queue"

# Frontend PORT
FRONTEND_PORT= 3001

# Sub. Client 端的環境變數
TUS_SERVER_HOST= "tus-server-local"
TUS_SERVER_PORT= 3003
NEXT_PUBLIC_TUS_SERVER_HOST= ${TARGET_HOST}
NEXT_PUBLIC_TUS_SERVER_PORT= ${TUS_SERVER_PORT}
